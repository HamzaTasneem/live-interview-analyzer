# Database: SQLite for dev, Postgres for prod
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="change-me-in-production"

# Storage: local | s3
STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH="./data/recordings"
# S3/MinIO (prod only)
S3_ENDPOINT=""
S3_BUCKET="recordings"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# LLM provider: anthropic | openai | none (template fallback)
LLM_PROVIDER="none"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Retention
RECORDING_RETENTION_DAYS=30
